<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.VBox?>

<?import javafx.scene.layout.HBox?>
<?import javafx.scene.image.ImageView?>


<?import javafx.scene.image.Image?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.Region?>

<?import javafx.scene.text.TextFlow?>
<?import javafx.scene.text.Text?>
<BorderPane fx:id="rootPane"
            styleClass="root-pane"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.tecnipcellstore.controller.DashboardController">

    <!-- SideBar -->
    <left>
        <HBox alignment="CENTER_LEFT">
            <padding>
                <Insets top="15.0" bottom="15.0"/>
            </padding>

            <!-- Espaciador Izquierdo -->
            <Region prefWidth="8" HBox.hgrow="NEVER"/>

            <!-- Barra Lateral -->
            <VBox fx:id="sidebarCategorias" styleClass="sidebar-compact" alignment="TOP_CENTER" spacing="12.0">
                <padding>
                    <Insets top="12.0" bottom="12.0"/>
                </padding>

                <!-- Logo -->
                <HBox alignment="CENTER">
                    <ImageView fitWidth="40" fitHeight="40" preserveRatio="true">
                        <image>
                            <Image url="@../images/sidebar/logo.jpg"/>
                        </image>
                    </ImageView>
                </HBox>

                <!-- Separador -->
                <Separator styleClass="sidebar-separator"/>

                <!-- Botones de Navegación -->

                <!-- dashboard -->
                <HBox fx:id="ganancia" styleClass="sidebar-icon-container" alignment="CENTER"
                      onMouseClicked="#onCategoryGananciaClick">
                    <ImageView fitWidth="22" fitHeight="22" preserveRatio="true">
                        <image>
                            <Image url="@../images/sidebar/dashboard.png"/>
                        </image>
                    </ImageView>
                    <Label text="Otros" styleClass="sidebar-icon-label" visible="false" managed="false"/>
                </HBox>

                <!-- Inventario -->
                <HBox fx:id="inventario" styleClass="sidebar-icon-container" alignment="CENTER"
                      onMouseClicked="#onCategoryInventarioClick">
                    <ImageView fitWidth="22" fitHeight="22" preserveRatio="true">
                        <image>
                            <Image url="@../images/sidebar/inventario.png"/>
                        </image>
                    </ImageView>
                    <Label text="Otros" styleClass="sidebar-icon-label" visible="false" managed="false"/>
                </HBox>

                <!-- Ventas -->
                <HBox fx:id="ventas" styleClass="sidebar-icon-container" alignment="CENTER"
                      onMouseClicked="#onCategoryVentasClick">
                    <ImageView fitWidth="22" fitHeight="22" preserveRatio="true">
                        <image>
                            <Image url="@../images/sidebar/venta.png"/>
                        </image>
                    </ImageView>
                    <Label text="Ventas" styleClass="sidebar-icon-label" visible="false" managed="false"/>
                </HBox>

                <!-- Compra -->
                <HBox fx:id="compra" styleClass="sidebar-icon-container" alignment="CENTER"
                      onMouseClicked="#onCategoryVentasClick">
                    <ImageView fitWidth="22" fitHeight="22" preserveRatio="true">
                        <image>
                            <Image url="@../images/sidebar/compra.png"/>
                        </image>
                    </ImageView>
                    <Label text="Ventas" styleClass="sidebar-icon-label" visible="false" managed="false"/>
                </HBox>

            </VBox>
        </HBox>
    </left>

    <!-- Contenido Principal -->
    <center>
        <VBox>
            <!-- Top Bar -->
            <HBox styleClass="top-bar" alignment="CENTER_LEFT">
                <padding>
                    <Insets left="15.0" top="15.0" bottom="15.0" right="15.0"/>
                </padding>
                <!-- Títulos -->
                <VBox alignment="CENTER_LEFT" spacing="2">
                    <padding>
                        <Insets top="10.0"/>
                    </padding>
                    <TextFlow>
                        <Text text="TecniStore" styleClass="top-bar-title"/>
                    </TextFlow>
                    <TextFlow>
                        <Text text="Bienvenido!" styleClass="top-bar-subtitle"/>
                    </TextFlow>
                </VBox>

            </HBox>

            <!-- Contenido Central (Crece) -->
            <VBox fx:id="centerContent" alignment="CENTER" spacing="20.0" VBox.vgrow="ALWAYS">
                <padding>
                    <Insets bottom="20.0" left="20.0" right="20.0" top="20.0"/>
                </padding>
            </VBox>
        </VBox>
    </center>

</BorderPane>
